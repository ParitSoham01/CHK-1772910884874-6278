<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HealthERP · B2B Healthcare ecosystem</title>
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- Google Fonts: Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }
        :root {
            --primary: #2c7da0;       /* soft healthcare blue */
            --primary-dark: #1f5f7a;
            --primary-light: #4a9fc5;
            --secondary: #61a5c2;
            --success: #2a9d8f;
            --warning: #e9c46a;
            --danger: #e76f51;
            --light: #f8f9fa;
            --gray: #6c757d;
            --dark: #1e2b37;
            --white: #ffffff;
            --sidebar-width: 280px;
            --header-height: 70px;
            --card-bg: rgba(255,255,255,0.9);
            --shadow: 0 8px 20px rgba(0,0,0,0.02), 0 2px 6px rgba(0,40,60,0.05);
            --radius: 24px;
        }
        body { background: #e6f2f5; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 16px; }
        /* main app container */
        .app-container { width: 100%; max-width: 1600px; height: 950px; background: var(--white); border-radius: 40px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.2); display: flex; flex-direction: column; overflow: hidden; position: relative; }
        /* LOGIN SCREEN (visible by default) */
        .login-screen { 
            display: flex; width: 100%; height: 100%; background: linear-gradient(145deg, #d9eef5 0%, #b3d9e8 100%);
            align-items: center; justify-content: center; z-index: 200; position: absolute; top:0; left:0; transition: all 0.3s ease;
        }
        .login-card {
            background: rgba(255,255,255,0.75); backdrop-filter: blur(16px); border-radius: 48px; padding: 48px 40px;
            width: 500px; box-shadow: var(--shadow); border: 1px solid rgba(255,255,255,0.7); text-align: center;
        }
        .login-card h2 { font-size: 2rem; color: var(--primary-dark); margin-bottom: 28px; }
        .role-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 16px; margin: 32px 0; }
        .role-btn {
            background: white; border: 1px solid rgba(0,0,0,0.04); padding: 20px 8px; border-radius: 28px;
            font-weight: 600; color: var(--dark); cursor: pointer; transition: 0.2s; box-shadow: 0 4px 8px rgba(0,0,0,0.02);
            display: flex; flex-direction: column; align-items: center; gap: 8px;
        }
        .role-btn i { font-size: 2.2rem; color: var(--primary); }
        .role-btn:hover { background: var(--primary); color: white; border-color: transparent; transform: scale(1.02); }
        .role-btn:hover i { color: white; }
        .login-footer { margin-top: 20px; color: var(--gray); font-size: 0.9rem; }

        /* DASHBOARD LAYOUT (hidden initially) */
        .dashboard-view { display: none; width: 100%; height: 100%; flex-direction: column; background: #f1f7fa; }
        .dashboard-view.active { display: flex; }

        /* top navigation */
        .top-nav {
            height: var(--header-height); background: rgba(255,255,255,0.6); backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(255,255,255,0.7); padding: 0 28px; display: flex; align-items: center; justify-content: space-between;
        }
        .logo-area { display: flex; align-items: center; gap: 12px; }
        .logo { font-size: 1.6rem; font-weight: 700; color: var(--primary-dark); }
        .role-badge { background: var(--primary-light); color: white; padding: 4px 16px; border-radius: 40px; font-weight: 600; font-size: 0.8rem; }
        .search-area { background: rgba(255,255,255,0.7); border-radius: 40px; padding: 8px 20px; width: 280px; display: flex; align-items: center; gap: 8px; }
        .search-area i { color: var(--gray); }
        .search-area input { border: none; background: transparent; outline: none; width: 100%; }
        .user-profile { display: flex; align-items: center; gap: 12px; background: rgba(255,255,255,0.6); padding: 6px 16px 6px 10px; border-radius: 40px; cursor: pointer; }
        .avatar { width: 38px; height: 38px; background: var(--primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; }

        /* main layout */
        .main-layout { display: flex; flex: 1; overflow: hidden; }
        .sidebar {
            width: var(--sidebar-width); background: rgba(255,255,255,0.5); backdrop-filter: blur(12px);
            border-right: 1px solid rgba(255,255,255,0.8); padding: 24px 0; overflow-y: auto;
        }
        .sidebar-menu { list-style: none; }
        .sidebar-menu li {
            display: flex; align-items: center; gap: 16px; padding: 14px 28px; margin: 4px 16px; border-radius: 16px;
            font-weight: 500; color: var(--dark); cursor: pointer; transition: 0.2s;
        }
        .sidebar-menu li i { width: 24px; font-size: 1.3rem; color: var(--primary-dark); }
        .sidebar-menu li:hover { background: rgba(255,255,255,0.7); color: var(--primary); }
        .sidebar-menu li.active { background: var(--primary); color: white; }
        .sidebar-menu li.active i { color: white; }

        /* content area pages */
        .content-area { flex: 1; overflow-y: auto; padding: 28px 32px; background: rgba(255,255,255,0.3); backdrop-filter: blur(4px); }
        .page { display: none; }
        .page.active-page { display: block; }

        /* cards & widgets */
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px,1fr)); gap: 20px; margin-bottom: 28px; }
        .stat-card {
            background: var(--card-bg); backdrop-filter: blur(6px); border-radius: 28px; padding: 24px; border: 1px solid rgba(255,255,255,0.7);
            display: flex; align-items: center; gap: 16px; box-shadow: var(--shadow);
        }
        .stat-icon { width: 56px; height: 56px; background: rgba(44,125,160,0.15); border-radius: 20px; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; color: var(--primary); }
        .stat-content h3 { font-size: 1.8rem; font-weight: 800; }
        .glass-card { background: var(--card-bg); backdrop-filter: blur(8px); border-radius: 28px; padding: 24px; border: 1px solid rgba(255,255,255,0.6); margin-bottom: 24px; }

        /* tables & forms */
        .table-responsive { overflow-x: auto; background: var(--card-bg); border-radius: 28px; padding: 8px; }
        table { width: 100%; border-collapse: collapse; }
        th { text-align: left; padding: 16px 12px; background: rgba(255,255,255,0.4); font-weight: 600; }
        td { padding: 14px 12px; border-bottom: 1px solid rgba(0,0,0,0.03); }
        .badge { background: rgba(44,125,160,0.12); color: var(--primary-dark); font-weight: 600; padding: 4px 12px; border-radius: 40px; font-size: 0.8rem; }
        .btn { background: var(--primary); color: white; border: none; padding: 8px 18px; border-radius: 34px; font-weight: 500; cursor: pointer; transition: 0.2s; }
        .btn-outline { background: transparent; border:1px solid var(--primary); color: var(--primary); }
        .btn-sm { padding: 6px 14px; font-size:0.8rem; }
        .form-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 16px; margin: 16px 0; }
        .form-group { display: flex; flex-direction: column; gap: 6px; }
        .form-group input, .form-group select, .form-group textarea { padding: 14px 16px; border-radius: 30px; border: 1px solid rgba(0,0,0,0.05); background: white; }

        .toast { position: fixed; top: 20px; right: 20px; background: white; padding: 14px 28px; border-radius: 60px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); border-left: 6px solid var(--primary); z-index: 9999; animation: slideIn 0.2s; }
        @keyframes slideIn { from { transform: translateX(100%); opacity:0; } to { transform: translateX(0); opacity:1; } }

        /* responsive */
        @media (max-width: 800px) { .stats-grid { grid-template-columns: 1fr 1fr; } }
    </style>
</head>
<body>
<div class="app-container">
    <!-- LOGIN SCREEN (visible initially) -->
    <div id="loginScreen" class="login-screen">
        <div class="login-card">
            <h2><i class="fas fa-hospital-user" style="color: var(--primary);"></i> HealthERP B2B</h2>
            <p style="margin-bottom: 10px;">Select your role to continue</p>
            <div class="role-grid">
                <div class="role-btn" onclick="loginAs('doctor')"><i class="fas fa-user-md"></i><span>Doctor</span></div>
                <div class="role-btn" onclick="loginAs('receptionist')"><i class="fas fa-clipboard-list"></i><span>Receptionist</span></div>
                <div class="role-btn" onclick="loginAs('admin')"><i class="fas fa-user-tie"></i><span>Hospital Admin</span></div>
                <div class="role-btn" onclick="loginAs('pharmacy')"><i class="fas fa-prescription-bottle"></i><span>Medical Store</span></div>
            </div>
            <div class="login-footer">demo login · no password required</div>
        </div>
    </div>

    <!-- DASHBOARD VIEW (hidden after login) -->
    <div id="dashboardView" class="dashboard-view">
        <!-- top nav (dynamic role) -->
        <nav class="top-nav" id="topNav">
            <div class="logo-area">
                <span class="logo"><i class="fas fa-heartbeat"></i> HealthERP</span>
                <span class="role-badge" id="roleBadge">Doctor</span>
            </div>
            <div class="search-area"><i class="fas fa-search"></i><input placeholder="Search patients, medicines..."></div>
            <div class="user-profile" onclick="showToast('Profile click (demo)')">
                <div class="avatar" id="userAvatar">D</div><span id="userDisplayName">Dr. Mehta</span><i class="fas fa-chevron-down"></i>
            </div>
        </nav>

        <div class="main-layout">
            <!-- sidebar dynamic (filled by js) -->
            <div class="sidebar" id="sidebarContainer"></div>

            <!-- content area pages will be injected via js, but we keep page placeholders -->
            <div class="content-area" id="contentArea"></div>
        </div>
    </div>
</div>

<script>
    // ---------- GLOBAL STATE ----------
    let currentRole = 'doctor';          // default fallback
    let currentPage = 'dashboard';
    const toast = (msg) => { let t = document.createElement('div'); t.className='toast'; t.innerText=msg; document.body.appendChild(t); setTimeout(()=>t.remove(),2500); };
    window.showToast = toast;

    // ---------- LOGIN FUNCTION ----------
    window.loginAs = function(role) {
        currentRole = role;
        document.getElementById('loginScreen').style.display = 'none';
        document.getElementById('dashboardView').classList.add('active');
        // update topnav role
        const roleMap = { doctor:'Doctor', receptionist:'Receptionist', admin:'Hospital Admin', pharmacy:'Medical Store' };
        document.getElementById('roleBadge').innerText = roleMap[role];
        let avatarLetter = { doctor:'D', receptionist:'R', admin:'A', pharmacy:'P' }[role];
        document.getElementById('userAvatar').innerText = avatarLetter;
        document.getElementById('userDisplayName').innerText = 
            role==='doctor'?'Dr. Mehta':role==='receptionist'?'Anita Sharma':role==='admin'?'Rajesh Khanna':'City Pharmacy';
        // render sidebar & first page
        renderSidebar(role);
        switchPage('dashboard');
    };

    // ---------- SIDEBAR MENU per role ----------
    function renderSidebar(role) {
        const menus = {
            doctor: ['Dashboard','My Patients','Patient Records','Prescriptions','Appointments','Reports','Profile','Settings'],
            receptionist: ['Dashboard','Register Patient','Patient Records','Appointment Management','Doctor Schedule','Billing Entry','Profile','Settings'],
            admin: ['Dashboard','Doctor Management','Staff Management','Patient Database','Medicine Inventory','Hospital Analytics','Reports','Settings'],
            pharmacy: ['Dashboard','Medicine Inventory','Supply Orders','Hospital Requests','Doctor Requests','Delivery Status','Reports','Settings']
        };
        let items = menus[role] || menus.doctor;
        let html = '<ul class="sidebar-menu">';
        items.forEach(p => {
            let icon = getIconForPage(p);
            html += `<li class="${p==='Dashboard'?'active':''}" onclick="switchPage('${p.toLowerCase().replace(/\s/g,'')}')"><i class="${icon}"></i><span>${p}</span></li>`;
        });
        html += '</ul>';
        document.getElementById('sidebarContainer').innerHTML = html;
    }

    function getIconForPage(p) {
        const map = { 'dashboard':'fas fa-chart-pie','my patients':'fas fa-users','patient records':'fas fa-folder-open','prescriptions':'fas fa-prescription',
            'appointments':'fas fa-calendar-check','reports':'fas fa-file-alt','profile':'fas fa-id-card','settings':'fas fa-sliders','register patient':'fas fa-user-plus',
            'appointment management':'fas fa-clock','doctor schedule':'fas fa-calendar','billing entry':'fas fa-credit-card','doctor management':'fas fa-user-md',
            'staff management':'fas fa-users-gear','patient database':'fas fa-database','medicine inventory':'fas fa-boxes','hospital analytics':'fas fa-chart-line',
            'inventory':'fas fa-pills','supply orders':'fas fa-truck','hospital requests':'fas fa-building','doctor requests':'fas fa-user-md','delivery status':'fas fa-location-dot' };
        return map[p.toLowerCase()] || 'fas fa-circle';
    }

    // ---------- PAGE SWITCHING ----------
    window.switchPage = function(pageId) {
        currentPage = pageId;
        // remove active from all sidebar items
        document.querySelectorAll('.sidebar-menu li').forEach(li => li.classList.remove('active'));
        // find and set active based on pageId
        document.querySelectorAll('.sidebar-menu li').forEach(li => {
            let text = li.querySelector('span')?.innerText.toLowerCase().replace(/\s/g,'') || '';
            if(text === pageId.toLowerCase().replace(/\s/g,'') || (pageId === 'dashboard' && text==='dashboard')) li.classList.add('active');
        });
        renderPageContent(pageId);
    };

    // ---------- RENDER DYNAMIC PAGE CONTENT ----------
    function renderPageContent(page) {
        const area = document.getElementById('contentArea');
        if (!area) return;
        // common header
        let title = page.split(/(?=[A-Z])/).join(' ').replace(/^\w/, c => c.toUpperCase());
        let html = `<h2 style="margin-bottom:24px">${title}</h2>`;

        if (currentRole === 'doctor') html += getDoctorPage(page);
        else if (currentRole === 'receptionist') html += getReceptionistPage(page);
        else if (currentRole === 'admin') html += getAdminPage(page);
        else if (currentRole === 'pharmacy') html += getPharmacyPage(page);

        area.innerHTML = html;
        attachEventListeners(); // for any dynamic buttons
    }

    // ********** DOCTOR PAGES **********
    function getDoctorPage(page) {
        if (page === 'dashboard') return `
            <div class="stats-grid">
                <div class="stat-card"><div class="stat-icon"><i class="fas fa-calendar-check"></i></div><div class="stat-content"><h3>8</h3><p>Today's appointments</p></div></div>
                <div class="stat-card"><div class="stat-icon"><i class="fas fa-users"></i></div><div class="stat-content"><h3>124</h3><p>My patients</p></div></div>
                <div class="stat-card"><div class="stat-icon"><i class="fas fa-flask"></i></div><div class="stat-content"><h3>12</h3><p>Lab reports</p></div></div>
            </div>
            <div class="glass-card"><h3>Today's schedule</h3><table><tr><th>Time</th><th>Patient</th><th>Reason</th></tr><tr><td>09:30</td><td>Ravi Kumar</td><td>Fever</td></tr><tr><td>10:15</td><td>Sunita Sharma</td><td>Diabetes follow-up</td></tr><tr><td>11:30</td><td>Arjun Singh</td><td>Chest pain</td></tr></table></div>`;
        if (page === 'mypatients') return `<div class="glass-card"><input placeholder="Search patients.." class="btn" style="width:40%; margin-bottom:16px"><table><tr><th>Name</th><th>Age</th><th>Last visit</th><th>Action</th></tr><tr><td>Meena Rai</td><td>45</td><td>12 Mar</td><td><button class="btn btn-sm" onclick="showToast('View records')">View</button></td></tr><tr><td>Rohit Mehra</td><td>38</td><td>10 Mar</td></tr></table></div>`;
        if (page === 'patientrecords') return `<div class="glass-card">Patient history · demo: <button class="btn" onclick="showToast('opening Sophia Ali')">Sophia Ali (P-234)</button> <pre style="margin-top:20px">Diagnosis: viral fever\nPrescription: Paracetamol 500mg</pre></div>`;
        if (page === 'prescriptions') return `<div class="glass-card"><textarea placeholder="Add diagnosis notes" rows="3" style="width:100%"></textarea><button class="btn" onclick="showToast('Prescription sent')">Prescribe</button></div>`;
        return `<div class="glass-card">${page} content (doctor demo) <br><button class="btn" onclick="showToast('demo')">ok</button></div>`;
    }

    // ********** RECEPTIONIST **********
    function getReceptionistPage(page) {
        if (page === 'dashboard') return `<div class="stats-grid"><div class="stat-card"><div class="stat-icon"><i class="fas fa-user-plus"></i></div><h3>5 new</h3><p>today</p></div><div class="stat-card"><div class="stat-icon"><i class="fas fa-calendar"></i></div><h3>18 app.</h3></div></div>`;
        if (page === 'registerpatient') return `
            <div class="glass-card"><h3>New patient registration</h3><div class="form-grid">
                <input placeholder="Full name"> <input placeholder="Age"> <select><option>Gender</option></select> <input placeholder="Phone">
                <input placeholder="Address"> <input placeholder="Symptoms"> <select><option>Assigned doctor</option><option>Dr. Mehta</option></select>
                <textarea placeholder="Previous history" rows="2"></textarea>
            </div><button class="btn" onclick="showToast('Patient registered (demo)')">Register patient</button></div>`;
        if (page === 'patientrecords') return `<div class="glass-card">Search: <input placeholder="patient ID"><button class="btn" onclick="showToast('show records')">view</button></div>`;
        if (page === 'appointmentmanagement') return `<div class="glass-card"><button class="btn" onclick="showToast('book appointment')">+ New appointment</button><table><tr><th>Patient</th><th>Doctor</th><th>Time</th></tr><tr><td>Raj</td><td>Dr. Mehta</td><td>11:20</td></tr></table></div>`;
        return `<div class="glass-card">${page} placeholder (receptionist)</div>`;
    }

    // ********** HOSPITAL ADMIN **********
    function getAdminPage(page) {
        if (page === 'dashboard') return `<div class="stats-grid">
            <div class="stat-card"><div class="stat-icon"><i class="fas fa-user"></i></div><h3>1,420</h3><p>patients</p></div>
            <div class="stat-card"><div class="stat-icon"><i class="fas fa-user-md"></i></div><h3>24</h3><p>doctors</p></div>
            <div class="stat-card"><div class="stat-icon"><i class="fas fa-box"></i></div><h3>2,800</h3><p>medicine stock</p></div>
            <div class="stat-card"><div class="stat-icon"><i class="fas fa-rupee-sign"></i></div><h3>₹8.2L</h3><p>monthly revenue</p></div>
        </div><div class="glass-card"><h3>inventory alerts</h3> paracetamol low ·  <button class="btn btn-sm" onclick="showToast('restock')">reorder</button></div>`;
        if (page === 'doctormanagement') return `<div class="glass-card"><button class="btn" onclick="showToast('add doctor')">+ add doctor</button><table><tr><th>Name</th><th>Dept</th></tr><tr><td>Dr. Mehta</td><td>Cardio</td></tr></table></div>`;
        if (page === 'staffmanagement') return `<div class="glass-card">staff list (receptionist, nurses) <button class="btn" onclick="showToast('edit')">edit</button></div>`;
        if (page === 'patientdatabase') return `<div class="glass-card">search all patients · <input><button class="btn">search</button></div>`;
        if (page === 'medicineinventory') return `<div class="glass-card"><table><tr><th>Medicine</th><th>Stock</th><th>Expiry</th></tr><tr><td>Paracetamol</td><td>4400</td><td>12/25</td></tr></table></div>`;
        return `<div class="glass-card">${page} (admin demo)</div>`;
    }

    // ********** PHARMACY **********
    function getPharmacyPage(page) {
        if (page === 'dashboard') return `<div class="stats-grid">
            <div class="stat-card"><div class="stat-icon"><i class="fas fa-box"></i></div><h3>2.4k</h3><p>stock items</p></div>
            <div class="stat-card"><div class="stat-icon"><i class="fas fa-truck"></i></div><h3>14</h3><p>pending orders</p></div>
        </div><div class="glass-card">low stock: azithromycin <button class="btn btn-sm" onclick="showToast('order to supplier')">order</button></div>`;
        if (page === 'medicineinventory') return `<div class="glass-card"><button class="btn" onclick="showToast('add medicine')"><i class="fas fa-plus"></i> add medicine</button><table><tr><th>Medicine</th><th>Batch</th><th>Expiry</th><th>Qty</th></tr><tr><td>Amox 250</td><td>B324</td><td>08/25</td><td>1200</td></tr></table></div>`;
        if (page === 'supplyorders') return `<div class="glass-card">Orders from hospitals: <button class="btn" onclick="showToast('dispatch')">dispatch</button></div>`;
        if (page === 'hospitalrequests') return `<div class="glass-card">Apollo hospital: 500 paracetamol <button class="btn">fulfill</button></div>`;
        return `<div class="glass-card">${page} (pharmacy demo)</div>`;
    }

    function attachEventListeners() {
        document.querySelectorAll('.btn').forEach(b => b.addEventListener('click', (e) => e.stopPropagation()));
    }

    // initial dashboard (after login, already called)
    window.switchPage = function(pageId) {
        currentPage = pageId;
        document.querySelectorAll('.sidebar-menu li').forEach(li => {
            li.classList.remove('active');
            let span = li.querySelector('span');
            if (span && span.innerText.toLowerCase().replace(/\s/g,'') === pageId.toLowerCase().replace(/\s/g,'')) li.classList.add('active');
        });
        renderPageContent(pageId);
    };

    // expose functions globally
    window.showToast = toast;
    window.loginAs = loginAs;
    window.switchPage = switchPage;

    // initial state: login screen visible
</script>
</body>
</html>
